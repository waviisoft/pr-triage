{
  "name": "pr-triage",
  "version": "0.1.0",
  "private": true,
  "description": "A \"whose move is it\" pull-request dashboard — a fully static, zero-service GitHub Pages app.",
  "license": "MIT",
  "author": "WAVIISoft, LLC",
  "homepage": "https://waviisoft.github.io/pr-triage/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/waviisoft/pr-triage.git"
  },
  "bugs": {
    "url": "https://github.com/waviisoft/pr-triage/issues"
  },
  "keywords": [
    "github",
    "pull-requests",
    "code-review",
    "dashboard",
    "triage",
    "react",
    "vite",
    "github-pages"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
